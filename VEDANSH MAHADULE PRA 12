
<html>
<head>
    <title>Skyline Properties</title>

    <Bootstrap CSS (only for grid & modal)>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .property-box {
            border: 1px solid #ccc;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 10px;
        }
        .property-box img {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }
    </style>
</head>

<body>

<!-- Navbar -->
<nav class="navbar bg-dark">
    <div class="container-fluid">
        <span class="text-white fs-4">Skyline Properties</span>
    </div>
</nav>

<div class="container mt-3">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-md-3">
            <h4>Filters</h4>

            <label>Price</label>
            <select class="form-select mb-3">
                <option>Select Price</option>
                <option>Below 50 Lakhs</option>
                <option>50L - 1Cr</option>
                <option>Above 1Cr</option>
            </select>

            <label>BHK</label>
            <select class="form-select">
                <option>Select BHK</option>
                <option>1 BHK</option>
                <option>2 BHK</option>
                <option>3 BHK</option>
            </select>
        </div>

        <!-- Properties -->
        <div class="col-md-9">

            <!-- Property 1 -->
            <div class="property-box">
                <img src="https://via.placeholder.com/300">
                <h5>2 BHK Apartment</h5>
                <p>₹60 Lakhs - Pune</p>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#m1">View Details</button>
            </div>

            <!-- Property 2 -->
            <div class="property-box">
                <img src="https://via.placeholder.com/300">
                <h5>3 BHK Villa</h5>
                <p>₹1.2 Cr - Mumbai</p>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#m2">View Details</button>
            </div>

            <!-- Property 3 -->
            <div class="property-box">
                <img src="https://via.placeholder.com/300">
                <h5>1 BHK Flat</h5>
                <p>₹35 Lakhs - Nagpur</p>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#m3">View Details</button>
            </div>

        </div>

    </div>
</div>

<!-- Modal 1 -->
<div class="modal fade" id="m1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>2 BHK Apartment</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Location: Pune</p>
                <p>Price: ₹60 Lakhs</p>
                <p>Area: 900 sq.ft</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal 2 -->
<div class="modal fade" id="m2">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>3 BHK Villa</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Location: Mumbai</p>
                <p>Price: ₹1.2 Cr</p>
                <p>Area: 2000 sq.ft</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal 3 -->
<div class="modal fade" id="m3">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>1 BHK Flat</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Location: Nagpur</p>
                <p>Price: ₹35 Lakhs</p>
                <p>Area: 600 sq.ft</p>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
